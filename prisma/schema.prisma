// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User model
model User {
  id                String    @id @default(cuid())
  username          String    @unique
  email             String?   @unique
  password          String
  usertype          String    @default("student")
  level             String?
  score             Int       @default(0)
  phoneNumber       String?   @unique
  age               Int?
  selectedProjectId String?
  selectedStoryId   String?
  storyPhase        Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions         Session[]
  selectedProject  Project?  @relation("SelectedProject", fields: [selectedProjectId], references: [id])
  selectedStory    Story?    @relation("SelectedStory", fields: [selectedStoryId], references: [id])
}

// NextAuth Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Project model — higher-level grouping
model Project {
  id        String   @id @default(cuid())
  title     String
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stories         Story[]
  selectedByUsers User[] @relation("SelectedProject")
}

// Story model — maps to old project's Project
model Story {
  id              String   @id @default(cuid())
  title           String
  content         String?  @db.Text
  imageUrl        String?  @db.Text
  audioUrl        String?  @db.Text
  rcQuestion      String?  @db.Text
  rcAnswer        String?
  ctQuestion      String?  @db.Text
  age             Int
  level           String
  projectId       String
  requireStoryId  String?
  requireChoice   String?
  depth           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project        Project        @relation(fields: [projectId], references: [id])
  selectedByUsers User[]        @relation("SelectedStory")
  requireStory    Story?         @relation("StoryBranch", fields: [requireStoryId], references: [id])
  childStories    Story[]        @relation("StoryBranch")
}
